# Example environment configuration for development and testing
# Copy this to .env and adjust values as needed

# Database Configuration
# For tests, use the Nix test database (set up by `nix develop .#test`):
DATABASE_URL=postgresql:///<your-username>?host=<project-root>/server/tmpdata/.pgdata-test

# OAuth/JWT Configuration
# For production, use real OAuth provider values
# For tests, use these dummy values:
OAUTH_CLIENT_ID=test-client-id
OAUTH_JWKS_URL=https://example.com/.well-known/jwks.json
OAUTH_TOKEN_URL=https://example.com/oauth/token
OAUTH_AUTHORIZE_URL=https://example.com/oauth/authorize

# JWT Secret (TEST MODE ONLY - for tests with symmetric key auth)
# In production, this should NOT be set (use JWKS instead)
JWT_SECRET=test-secret-key-for-testing-only

# Storage Directories
STORAGE_BASE_DIRECTORY=./server/tmpdata/test-storage
STORAGE_CACHE_DIRECTORY=./server/tmpdata/test-cache
STORAGE_TEMP_DIRECTORY=./server/tmpdata/test-tmp

# Logging Level (trace, debug, info, warn, error)
RUST_LOG=info